# ─── Platform Configuration ────────────────────────────────────────────────────
# The root domain for your platform. Orgs get subdomains like "acme.yourdomain.com"
PLATFORM_DOMAIN=yourdomain.com

# ─── Database (Neon PostgreSQL) ─────────────────────────────────────────────────
# 1. Go to https://neon.tech and create a free project
# 2. Copy the connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Google OAuth ───────────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/
# 2. Create a project → APIs & Services → Credentials → OAuth 2.0 Client ID
# 3. Application type: Web application
# 4. Authorized redirect URIs:
#    - http://localhost:3000/api/auth/callback/google (dev)
#    - https://yourdomain.com/api/auth/callback/google (prod)
#    - https://yourdomain.com/api/admin/drive-callback (Drive OAuth)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── NextAuth ───────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your_random_secret
NEXTAUTH_URL=http://localhost:3000

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# 1. Go to https://resend.com and create an account
# 2. Verify your sending domain
# 3. Create an API key
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=Data Room <noreply@yourdomain.com>

# ─── AI Chat (Optional) ────────────────────────────────────────────────────────
# Only needed if you want the AI chat feature
ANTHROPIC_API_KEY=sk-ant-your_key

# ─── File Storage (Vercel Blob - Production) ───────────────────────────────────
# Automatically provided by Vercel when you add Blob storage
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ─── Public Environment Variables ──────────────────────────────────────────────
NEXT_PUBLIC_PLATFORM_DOMAIN=yourdomain.com
