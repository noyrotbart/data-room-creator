# Google OAuth credentials (from Google Cloud Console)
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project (or use existing)
# 3. APIs & Services > Credentials > Create Credentials > OAuth 2.0 Client ID
# 4. Application type: Web application
# 5. Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
# 6. Copy the Client ID and Client Secret below

GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Admin email — this account can see the analytics dashboard
ADMIN_EMAIL=your@email.com

# Path to documents folder (absolute path)
DOCUMENTS_PATH=/Users/noyrotbart/Downloads/data-room/documents_raw/Data Room
